   ],
   "source": [
    "smote = SMOTE(random_state=42)\n",
    "X_train_res, y_train_res = smote.fit_resample(X_train, y_train)\n",
    "print(f\"Après SMOTE → {y_train_res.value_counts().to_dict()}\")"
   ]
  },
